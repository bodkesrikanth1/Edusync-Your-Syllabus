# Flask Configuration 
FLASK_SECRET=your-secret-key-here-change-in-production

# Database Configuration
# Option 1: MySQL (for local database)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=edusync

# Option 2: SQLite (for local file-based database)
# Set DB_TYPE=sqlite to use SQLite instead of MySQL
DB_TYPE=mysql

# YouTube API
YT_API_KEY=your-youtube-api-key-here

# Flask Port (for local development)
FLASK_PORT=5000